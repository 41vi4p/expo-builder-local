# Copy this file to .env and fill in the values below, then:
#   make build-image   # builds the Android toolchain image (large, one-time)
#   docker compose up  # starts the GUI + orchestrator

# --- Required --------------------------------------------------------------------

# Absolute host path to the directory tree containing the Expo project(s) you want to
# build (a parent folder is fine — the GUI's directory browser lets you navigate into
# it). This exact path is bind-mounted into the orchestrator container AND used as its
# ALLOWED_ROOTS — the two must always match (see docker-compose.yml).
# Example: if your apps live at /home/alex/code/CanteenApp and /home/alex/code/CRCEats-CS,
# set this to /home/alex/code.
HOST_PROJECTS_ROOT=/home/youruser/code

# Encrypts uploaded keystore passwords at rest (AES-256-GCM). Generate one with:
#   openssl rand -base64 32
MASTER_KEY=

# --- Recommended -------------------------------------------------------------------

# Your host user's UID/GID, so build output written into your project folder (and the
# npm/Gradle cache volumes) is owned by you instead of root. Find them with `id -u`
# and `id -g`.
HOST_UID=1000
HOST_GID=1000

# --- Optional ------------------------------------------------------------------------

# Ports the GUI and orchestrator API are reachable at from your host (both bind to
# 127.0.0.1 only — see docker-compose.yml).
WEB_PORT=3000
ORCHESTRATOR_PORT=4001

# The orchestrator URL your *browser* will call — usually http://localhost:<ORCHESTRATOR_PORT>.
# Baked into the web image at build time (Next.js inlines NEXT_PUBLIC_* at build), so
# re-run `docker compose build web` if you change this.
ORCHESTRATOR_PUBLIC_URL=http://localhost:4001

# An Expo access token (https://expo.dev/accounts/[account]/settings/access-tokens).
# Only needed if you want the "auto"/"eas" build engine to use `eas build --local`
# instead of the fully offline `expo prebuild` + Gradle path. Leave blank to always
# build locally with no Expo account involved.
EXPO_TOKEN=

# How many builds run at once. Each build is a full Android/Gradle toolchain — keep
# this at 1 unless your machine has cores and RAM to spare (Gradle alone wants several
# GB of heap).
MAX_CONCURRENT_BUILDS=1

# CORS origin allowed to call the orchestrator API. "*" is fine for local-only use
# (both services bind to 127.0.0.1); tighten this if you expose the ports further.
CORS_ORIGIN=*

# Docker image tag for the Android runner (rarely needs changing).
RUNNER_IMAGE=expo-builder-local-runner:latest
